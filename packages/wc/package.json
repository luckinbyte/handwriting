{
  "name": "@handwriting/wc",
  "version": "0.1.0",
  "description": "<handwriting-stream> Web Component for @handwriting/core — streaming handwriting.",
  "type": "module",
  "license": "MIT",
  "keywords": ["handwriting", "stroke-order", "hanzi-writer", "streaming", "web-component", "custom-element"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auto": {
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@handwriting/core": "workspace:*"
  },
  "devDependencies": {
    "@handwriting/core": "workspace:*"
  }
}
