{
  "name": "handwriting",
  "private": true,
  "version": "0.0.0",
  "description": "Streaming handwriting animation for the web — Chinese stroke order + Latin fade, framework-agnostic.",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @handwriting/core build && pnpm -r --filter=./packages/* exec tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "demo": "pnpm --filter demo dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.12",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
